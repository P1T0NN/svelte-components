# --- Convex ---
# Set automatically by `bunx convex dev` on first run; the CLI will fill these in.
CONVEX_DEPLOYMENT=
PUBLIC_CONVEX_URL=

# --- App ---
# Public URL of the SvelteKit app. Better Auth uses this to build OAuth callback
# URLs and verification links. In dev: http://localhost:5173
SITE_URL=http://localhost:5173

# --- Better Auth ---
# 32+ char random string. Generate: `openssl rand -base64 32`
BETTER_AUTH_SECRET=

# --- Google OAuth ---
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URI: ${SITE_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Resend (transactional email) ---
# https://resend.com/api-keys
RESEND_API_KEY=
